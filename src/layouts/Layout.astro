---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'UAT Solutions Inc. connects shippers and carriers across North America with speed, reliability, and cost-efficiency.',
  image = '/og-image.jpg',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="SdFEDs0PzFoWvGbzmKfAA0GFcFZeBVWp_OigxIqM_7o" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400;1,600;1,700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-cream text-dark">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Sticky nav scroll behavior
      const header = document.querySelector('#site-header') as HTMLElement | null;
      if (header) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 60) {
            header.classList.add('nav-scrolled');
          } else {
            header.classList.remove('nav-scrolled');
          }
        }, { passive: true });
      }

      // Mobile menu toggle
      const hamburger = document.querySelector('#hamburger-btn');
      const mobileNav = document.querySelector('#mobile-nav');
      const closeBtn = document.querySelector('#mobile-close');

      function openNav() {
        mobileNav?.classList.remove('closed');
        mobileNav?.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeNav() {
        mobileNav?.classList.remove('open');
        mobileNav?.classList.add('closed');
        document.body.style.overflow = '';
      }

      hamburger?.addEventListener('click', openNav);
      closeBtn?.addEventListener('click', closeNav);
      mobileNav?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav));
    </script>
  </body>
</html>
