---
const navLinks = [
  { label: 'Home',     href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'News',     href: '/news' },
  { label: 'Contact',  href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<!-- Announcement Ticker -->
<div class="bg-dark text-cream/70 text-xs overflow-hidden py-2.5 relative z-50">
  <div class="flex ticker-track">
    {Array(2).fill(null).map(() => (
      <span class="flex items-center gap-8 px-8">
        <span>✦ North America's Trusted Freight Partner</span>
        <span>✦ FTL · LTL · Cross-Border Freight · Personalized Freight Services</span>
        <span>✦ 1-647-704-9045</span>
        <span>✦ contact@uat-solutions.com</span>
        <span>✦ Serving Canada &amp; the United States</span>
        <span>✦ Competitive Rates · Zero Hidden Fees</span>
      </span>
    ))}
  </div>
</div>

<!-- Main Navigation -->
<header id="site-header" class="sticky top-0 z-40 bg-dark transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-16 lg:h-20">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group" aria-label="UAT Solutions Home">
      <!-- U-Arrow Icon -->
      <svg class="h-11 lg:h-14 w-auto flex-shrink-0" viewBox="0 0 80 88" fill="none" xmlns="https://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="hIconGrad" x1="40" y1="0" x2="40" y2="88" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#CC1A2D"/>
            <stop offset="60%" stop-color="#B0151F"/>
            <stop offset="100%" stop-color="#8A0F18"/>
          </linearGradient>
        </defs>
        <rect x="2"    y="22" width="21" height="56" rx="5"  fill="url(#hIconGrad)"/>
        <rect x="57"   y="22" width="21" height="56" rx="5"  fill="url(#hIconGrad)"/>
        <rect x="2"    y="62" width="76" height="24" rx="12" fill="url(#hIconGrad)"/>
        <rect x="29.5" y="26" width="21" height="56"         fill="url(#hIconGrad)"/>
        <polygon points="40,2 16,26 64,26" fill="#CC1A2D"/>
      </svg>

      <!-- Divider -->
      <span class="hidden sm:block h-8 w-px opacity-40" style="background: #F0A8B5;"></span>

      <!-- Wordmark -->
      <span class="flex flex-col leading-none">
        <span class="font-black text-cream text-2xl lg:text-3xl tracking-tight group-hover:text-cream/90 transition-colors" style="font-family: 'Arial Black', 'Helvetica Neue', Arial, sans-serif; letter-spacing: -0.02em;">
          UAT
        </span>
        <span class="text-[10px] lg:text-[12px] font-bold tracking-[0.22em] uppercase transition-colors" style="color: #C0192B; letter-spacing: 0.22em;">
          SOLUTIONS INC.
        </span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'font-body text-base font-medium tracking-wide transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-cream'
              : 'text-cream/60 hover:text-cream',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        class="ml-2 bg-accent hover:bg-accent-hover text-light text-base font-semibold px-5 py-2.5 transition-colors"
      >
        Get a Quote
      </a>
    </nav>

    <!-- Hamburger (mobile) -->
    <button
      id="hamburger-btn"
      class="lg:hidden flex flex-col gap-1.5 p-2 text-cream"
      aria-label="Open menu"
    >
      <span class="block w-6 h-0.5 bg-current"></span>
      <span class="block w-6 h-0.5 bg-current"></span>
      <span class="block w-4 h-0.5 bg-current"></span>
    </button>
  </div>
</header>

<!-- Mobile Nav Drawer -->
<div id="mobile-nav" class="closed fixed inset-0 z-50 bg-dark flex flex-col lg:hidden">
  <div class="flex items-center justify-between px-6 h-16 border-b border-white/10">

    <!-- Logo in drawer -->
    <a href="/" class="flex items-center gap-3">
      <svg class="h-9 w-auto" viewBox="0 0 80 88" fill="none" xmlns="https://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="mIconGrad" x1="40" y1="0" x2="40" y2="88" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#CC1A2D"/>
            <stop offset="100%" stop-color="#8A0F18"/>
          </linearGradient>
        </defs>
        <rect x="2"    y="22" width="21" height="56" rx="5"  fill="url(#mIconGrad)"/>
        <rect x="57"   y="22" width="21" height="56" rx="5"  fill="url(#mIconGrad)"/>
        <rect x="2"    y="62" width="76" height="24" rx="12" fill="url(#mIconGrad)"/>
        <rect x="29.5" y="26" width="21" height="56"         fill="url(#mIconGrad)"/>
        <polygon points="40,2 16,26 64,26" fill="#CC1A2D"/>
      </svg>
      <span class="flex flex-col leading-none">
        <span class="font-black text-cream text-xl tracking-tight" style="font-family: 'Arial Black', 'Helvetica Neue', Arial, sans-serif;">UAT</span>
        <span class="text-[9px] font-bold tracking-[0.22em] uppercase" style="color: #C0192B;">SOLUTIONS INC.</span>
      </span>
    </a>

    <button id="mobile-close" class="text-cream/70 hover:text-cream p-2" aria-label="Close menu">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav class="flex flex-col px-6 pt-10 gap-2">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="font-display text-3xl text-cream/80 hover:text-cream py-2 border-b border-white/5 transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/contact"
      class="mt-6 inline-block bg-accent hover:bg-accent-hover text-light text-base font-semibold px-6 py-3 text-center transition-colors"
    >
      Get a Free Quote
    </a>
  </nav>

  <div class="mt-auto px-6 pb-10 text-cream/40 text-sm">
    <p>1-647-704-9045</p>
    <p>contact@uat-solutions.com</p>
  </div>
</div>
