---
const year = new Date().getFullYear();
---

<footer class="bg-dark text-cream">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-16 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-6 group">
          <!-- U-Arrow Icon -->
          <svg class="h-10 w-auto flex-shrink-0" viewBox="0 0 80 88" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <linearGradient id="ftIconGrad" x1="40" y1="0" x2="40" y2="88" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#CC1A2D"/>
                <stop offset="60%" stop-color="#B0151F"/>
                <stop offset="100%" stop-color="#8A0F18"/>
              </linearGradient>
            </defs>
            <rect x="2"    y="22" width="21" height="56" rx="5"  fill="url(#ftIconGrad)"/>
            <rect x="57"   y="22" width="21" height="56" rx="5"  fill="url(#ftIconGrad)"/>
            <rect x="2"    y="62" width="76" height="24" rx="12" fill="url(#ftIconGrad)"/>
            <rect x="29.5" y="26" width="21" height="56"         fill="url(#ftIconGrad)"/>
            <polygon points="40,2 16,26 64,26" fill="#CC1A2D"/>
          </svg>
          <!-- Divider -->
          <span class="h-8 w-px opacity-30" style="background: #F0A8B5;"></span>
          <!-- Wordmark -->
          <span class="flex flex-col leading-none">
            <span class="font-black text-cream text-xl tracking-tight group-hover:text-cream/80 transition-colors" style="font-family: 'Arial Black', 'Helvetica Neue', Arial, sans-serif; letter-spacing: -0.02em;">UAT</span>
            <span class="text-[9px] font-bold tracking-[0.22em] uppercase" style="color: #C0192B;">SOLUTIONS INC.</span>
          </span>
        </a>
        <p class="text-cream/60 text-sm leading-relaxed max-w-xs mb-6">
          Connecting shippers and carriers across North America with speed, reliability, and cost-efficiency. Your freight moves — we make sure of it.
        </p>
        <div class="flex flex-col gap-2 text-sm text-cream/50">
          <a href="tel:16477049045" class="hover:text-cream transition-colors">
            📞 1-647-704-9045
          </a>
          <a href="mailto:contact@uat-solutions.com" class="hover:text-cream transition-colors">
            ✉️ contact@uat-solutions.com
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-cream/40 text-xs tracking-[0.2em] uppercase font-medium mb-5">Services</h4>
        <ul class="flex flex-col gap-3">
          {[
            ['Full Truckload (FTL)', '/services#ftl'],
            ['Less-Than-Truckload (LTL)', '/services#ltl'],
            ['Temperature Controlled', '/services#reefer'],
            ['Carrier Partnerships', '/services#carriers'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-cream/60 text-sm hover:text-cream transition-colors link-underline">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-cream/40 text-xs tracking-[0.2em] uppercase font-medium mb-5">Company</h4>
        <ul class="flex flex-col gap-3">
          {[
            ['Home', '/'],
            ['Services', '/services'],
            ['News', '/news'],
            ['Contact Us', '/contact'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-cream/60 text-sm hover:text-cream transition-colors link-underline">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-cream/30 text-xs">
      <span>© {year} UAT Solutions Inc. All rights reserved.</span>
      <span class="hidden sm:block">Licensed Freight Broker — Serving Canada & United States</span>
    </div>
  </div>
</footer>
