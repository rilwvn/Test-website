---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'news'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.pubDate.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Related posts
const allPosts = await getCollection('news');
const related = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .slice(0, 2);
---

<Layout
  title={`${post.data.title} | UAT Solutions`}
  description={post.data.description}
  image={post.data.image}
>

  <!-- Article header -->
  <section class="bg-dark pt-16 pb-28 px-6 relative overflow-hidden">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[160%] h-24 md:h-36 bg-cream hero-arch" aria-hidden="true"></div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <div class="mb-6">
        <a href="/news" class="text-cream/50 hover:text-cream text-sm transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
          </svg>
          Back to News
        </a>
      </div>
      <span class="bg-accent text-light text-[10px] font-semibold tracking-[0.2em] uppercase px-3 py-1">
        {post.data.category}
      </span>
      <h1 class="font-display text-3xl md:text-5xl font-bold text-cream mt-5 mb-5 leading-tight">
        {post.data.title}
      </h1>
      <time class="text-cream/40 text-sm">{formattedDate}</time>
    </div>
  </section>

  <!-- Hero image -->
  {post.data.image && (
    <div class="max-w-5xl mx-auto px-6 -mt-8 relative z-10">
      <div class="aspect-[16/7] overflow-hidden bg-dark-2">
        <img
          src={post.data.image}
          alt={post.data.imageAlt ?? post.data.title}
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    </div>
  )}

  <!-- Article body -->
  <article class="bg-cream py-16 px-6">
    <div class="max-w-2xl mx-auto">
      <div class="prose prose-lg prose-uat max-w-none font-body">
        <Content />
      </div>
    </div>
  </article>

  <!-- Related articles -->
  {related.length > 0 && (
    <section class="bg-cream-2 py-16 px-6 border-t border-dark/10">
      <div class="max-w-7xl mx-auto">
        <h2 class="font-display text-2xl font-bold text-dark mb-8">
          Related <em class="italic font-normal">Articles</em>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-dark/10">
          {related.map(p => (
            <div class="card-lift">
              <a href={`/news/${p.slug}`} class="block bg-cream p-8 group h-full">
                <span class="text-accent text-[10px] font-semibold tracking-[0.2em] uppercase">{p.data.category}</span>
                <h3 class="font-display text-xl font-bold text-dark mt-2 mb-3 group-hover:text-accent transition-colors leading-snug">
                  {p.data.title}
                </h3>
                <p class="text-mid text-sm line-clamp-2 leading-relaxed">{p.data.description}</p>
                <span class="inline-flex items-center gap-1.5 mt-4 text-dark text-sm font-medium group-hover:gap-2.5 transition-all">
                  Read article →
                </span>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Bottom CTA -->
  <section class="bg-dark py-16 px-6 text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-cream mb-4">
        Need to move freight <em class="italic font-normal">now?</em>
      </h2>
      <p class="text-cream/60 mb-8 text-sm">Get a free quote from our team — fast, competitive, no surprises.</p>
      <a href="/contact" class="inline-block bg-accent hover:bg-accent-hover text-light font-semibold px-8 py-4 text-sm tracking-wide transition-colors">
        Get a Free Quote
      </a>
    </div>
  </section>

</Layout>
